FACEBOOK_PAGE_ID=your_page_id_here
FACEBOOK_ACCESS_TOKEN=your_facebook_token_here
LINKEDIN_USER_ID=your_linkedin_urn_here
LINKEDIN_ACCESS_TOKEN=your_linkedin_token_here
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here

# Comma-separated "owner/repo" list to scan for new releases
TARGET_REPOS=jessn-dev/some-repo,jessn-dev/another-repo
# Optional: raises GitHub API rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=your_github_token_here

# Optional: blog | github | all (default all)
RUN_MODE=all
# Optional: set true to print generated posts without publishing
DRY_RUN=false

POST_TOPIC="Write a post about my newest open-source project called smm-bot, an automated cross-posting tool built in Node.js"
